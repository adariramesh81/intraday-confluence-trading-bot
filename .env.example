APP_ENV=development
LOG_LEVEL=INFO
LOG_FILE_PATH=logs/trading_bot.log

ALPACA_API_KEY=replace_me
ALPACA_SECRET_KEY=replace_me
ALPACA_PAPER=true

LIVE_TRADING=false
DEFAULT_SYMBOL=SPY
MAX_TRADES_PER_DAY=3
RISK_PER_TRADE=0.01

MARKET_DATA_SOURCE=alpaca
MARKET_DATA_TIMEFRAME=1Min
MARKET_DATA_FEED=iex
MARKET_DATA_ADJUSTMENT=raw
MARKET_DATA_TIMEZONE=America/New_York
MARKET_DATA_RETRY_ATTEMPTS=3
MARKET_DATA_RETRY_BACKOFF_SECONDS=1.0
MARKET_DATA_TIMEOUT_SECONDS=30

DASHBOARD_HOST=127.0.0.1
DASHBOARD_PORT=8000
DASHBOARD_REFRESH_SECONDS=5
DASHBOARD_AUTH_ENABLED=false
DASHBOARD_USERNAME=
DASHBOARD_PASSWORD=
DASHBOARD_SESSION_SECRET=

ALERTS_ENABLED=false
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
EMAIL_ALERTS_ENABLED=false
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
ALERT_EMAIL_FROM=
ALERT_EMAIL_TO=

SQLITE_PATH=data/trading_bot.sqlite3
ALPACA_SYNC_ENABLED=true
ALPACA_SYNC_REFRESH_SECONDS=30
ALPACA_SYNC_ORDER_LIMIT=500
ALPACA_SYNC_PORTFOLIO_HISTORY_DAYS=30
